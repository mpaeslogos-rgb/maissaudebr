// ============================================
// CONFIGURAÇÃO
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Config {
  id   String @id @default(cuid())
  key  String @unique @default("clinic")

  // Dados da clínica
  clinicName      String @default("maissaudebr")
  cnpj            String @default("")
  cnes            String @default("") // Cadastro Nacional de Estabelecimentos de Saúde
  address         String @default("")
  whatsappNumber  String @default("")
  attendanceHours String @default("")
  specialties     String @default("")

  // Telemedicina
  telemedicinePlatform     String @default("")
  telemedicineLinkInfo     String @default("")
  telemedicineInstructions String @default("")
  linkSendTime             String @default("")

  // Pagamentos
  defaultConsultationFee String @default("")
  pixKey                 String @default("")
  paymentLink            String @default("")
  paymentMethods         String @default("")
  paymentInstructions    String @default("")

  // Políticas da clínica
  confirmationPolicy String @default("")
  cancellationPolicy String @default("")

  // Mensagens automáticas para WhatsApp
  welcomeMessage         String @default("")
  confirmationMessage    String @default("")
  reminderMessage        String @default("")
  paymentReminderMessage String @default("")
  humanTransferMessage   String @default("")
  emergencyMessage       String @default("")

  // Regras adicionais para a IA
  otherSettings String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("configs")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PATIENT
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BANK_TRANSFER
  HEALTH_INSURANCE
}

enum AccountPayableStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ============================================
// USUÁRIOS E AUTENTICAÇÃO
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(RECEPTIONIST)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações 1:1 (um User pode ser um Doctor ou um Patient)
  doctor    Doctor?
  patient   Patient?
  auditLogs AuditLog[]

  @@index([email])
  @@map("users")
}

// ============================================
// MÉDICOS
// ============================================

model Doctor {
  id           String   @id @default(cuid())
  userId       String   @unique
  crm          String   @unique // Conselho Regional de Medicina
  crmState     String   // UF do CRM (ex: "SP", "RJ")
  cpf          String?  // CPF do médico — obrigatório para prescrição digital CFM
  specialty    String
  phone        String?
  bio          String?
  consultationFee Float?
  workStartHour Int      @default(8)
  workEndHour   Int      @default(18)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  prescriptions   Prescription[]
  transferredChats Chat[]

  @@index([crm])
  @@index([specialty])
  @@map("doctors")
}

// ============================================
// PACIENTES
// ============================================

model Patient {
  id          String    @id @default(cuid())
  userId      String?   @unique // Opcional: paciente pode não ter login
  fullName    String
  cpf         String?   @unique  // Opcional para pacientes criados via WhatsApp
  rg          String?
  birthDate   DateTime?          // Opcional para pacientes criados via WhatsApp
  gender      Gender?            // Opcional para pacientes criados via WhatsApp
  email       String?
  phone       String
  
  // Endereço
  zipCode     String?
  street      String?
  number      String?
  complement  String?
  neighborhood String?
  city        String?
  state       String?

  // Dados clínicos
  bloodType   String?
  allergies   String?
  notes       String?

  // Convênio
  healthInsurance     String?
  healthInsuranceNumber String?

  // Foto
  photoUrl    String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  payments        Payment[]
  chats           Chat[]
  exams           Exam[]
  prescriptions   Prescription[]
  consents        Consent[]

  @@index([cpf])
  @@index([fullName])
  @@map("patients")
}

// ============================================
// LGPD — CONSENTIMENTO (Art. 7 e Art. 9)
// ============================================
// Registra o consentimento explícito do paciente para cada finalidade de tratamento.
// Finalidades típicas: "tratamento_clinico", "marketing", "compartilhamento_parceiros", etc.

model Consent {
  id          String   @id @default(cuid())
  patientId   String
  purpose     String   // Finalidade do tratamento (ex: "tratamento_clinico")
  granted     Boolean  @default(true) // true = consentiu, false = revogou
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  notes       String?

  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([patientId, purpose])
  @@map("consents")
}

// ============================================
// PRE AGENDAMENTOS
// ============================================

model PreAppointment {
  id          String   @id @default(cuid())
  leadId      String
  doctorId    String
  date        String   // Formato YYYY-MM-DD
  time        String   // Formato HH:MM
  specialty   String
  status      String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pre_appointments")
}

// ============================================
// AGENDAMENTOS
// ============================================

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String
  startTime   DateTime
  endTime     DateTime
  status      AppointmentStatus @default(SCHEDULED)
  reason      String?           // Motivo da consulta
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor         Doctor          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  medicalRecord  MedicalRecord?
  prescription   Prescription?
  payment        Payment?

  @@index([patientId])
  @@index([doctorId])
  @@index([startTime])
  @@index([status])
  @@map("appointments")
}

// ============================================
// PRONTUÁRIOS MÉDICOS
// ============================================

model MedicalRecord {
  id              String   @id @default(cuid())
  patientId       String
  doctorId        String
  appointmentId   String?  @unique // 1:1 opcional com Appointment
  
  // Anamnese e diagnóstico
  chiefComplaint   String?  // Queixa principal
  historyOfIllness String?  // História da doença atual
  diagnosis        String?
  prescription     String?  // Prescrição
  observations     String?

  // Sinais vitais
  bloodPressure    String?  // ex: "120/80 mmHg"
  heartRate        Int?     // bpm
  temperature      Float?   // °C
  weight           Float?   // kg
  height           Float?   // cm
  oxygenSaturation Float?   // %

  // Histórico clínico estruturado
  currentMedications String? // Medicamentos em uso
  pastConditions     String? // Antecedentes pessoais
  pastSurgeries      String? // Cirurgias anteriores
  familyHistory      String? // Histórico familiar

  // Hábitos de vida
  smokingStatus    String?  // NEVER | FORMER | CURRENT
  alcoholStatus    String?  // NEVER | OCCASIONAL | REGULAR
  physicalActivity String?  // SEDENTARY | LIGHT | MODERATE | INTENSE

  // Perguntas específicas da especialidade (JSON livre)
  specialtyData    Json?

  // OCR / Anexos (resultados de exames extraídos via OpenAI)
  attachmentUrl   String?  // URL do arquivo original (se salvar storage)
  ocrText         String?  // Texto extraído via OCR
  ocrSummary      String?  // Resumo gerado pela OpenAI

  // Transcrição da consulta
  transcript      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  exams        Exam[]

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@map("medical_records")
}

// ============================================
// EXAMES E RESULTADOS
// ============================================

enum ExamType {
  LABORATORY
  IMAGING
  REPORT
  OTHER
}

model Exam {
  id              String    @id @default(cuid())
  patientId       String
  medicalRecordId String?

  name            String
  type            ExamType  @default(OTHER)
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  mimeType        String?
  ocrText         String?
  notes           String?
  examDate        DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicalRecord MedicalRecord? @relation(fields: [medicalRecordId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([medicalRecordId])
  @@map("exams")
}

// ============================================
// PAGAMENTOS (CONTAS A RECEBER)
// ============================================

model Payment {
  id              String         @id @default(cuid())
  patientId       String
  appointmentId   String?        @unique
  amount          Float
  status          PaymentStatus  @default(PENDING)
  method          PaymentMethod?
  dueDate         DateTime
  paidAt          DateTime?
  description     String?
  invoiceUrl      String?        // Link da nota fiscal (se houver)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

// ============================================
// CONTAS A PAGAR (despesas da clínica)
// ============================================

model AccountPayable {
  id          String               @id @default(cuid())
  description String
  category    String?              // Ex: "Aluguel", "Energia", "Material"
  supplier    String?              // Fornecedor
  supplierCnpj  String?
  digitableLine String?
  barcode       String?
  bankCode      String?
  fileUrl       String?
  ocrRawText    String?
  ocrConfidence Float?
  ocrStatus     String   @default("PENDING")
  amount      Float
  status      AccountPayableStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([category])
  @@map("accounts_payable")
}

// ============================================
// AUDITORIA (LGPD / rastreabilidade)
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // Ex: "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity     String   // Ex: "Patient", "Appointment"
  entityId   String?
  metadata   Json?    // Dados adicionais (antes/depois, IP, etc.)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  specialty String?
  status    String   @default("NOVO")

  // Campos opcionais capturados na importação Excel
  cpf                   String?
  rg                    String?
  birthDate             DateTime?
  gender                String?
  email                 String?
  zipCode               String?
  street                String?
  number                String?
  complement            String?
  neighborhood          String?
  city                  String?
  state                 String?
  bloodType             String?
  allergies             String?
  notes                 String?
  healthInsurance       String?
  healthInsuranceNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model ChatLog {
  id        String   @id @default(cuid())
  phone     String   @default("simulador")
  intent    String?  // agendamento, pagamento, urgencia, humano, etc.
  message   String
  isUser    Boolean  @default(true)
  
  createdAt DateTime @default(now())

  @@map("chat_logs")
}

model Chat {
  id          String      @id @default(cuid())
  phone       String      @unique
  patientId   String?
  status      ChatStatus  @default(ACTIVE)
  aiPaused    Boolean     @default(false)
  transferredToDoctorId   String?
  pendingTransferDoctorId String?
  lastMessageAt DateTime  @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  patient     Patient?    @relation(fields: [patientId], references: [id])
  doctor      Doctor?     @relation(fields: [transferredToDoctorId], references: [id])

  @@map("chats")
}

enum ChatStatus {
  ACTIVE
  TRANSFERRED_TO_DOCTOR
  CLOSED
}

// ============================================
// PRESCRIÇÕES MÉDICAS
// ============================================

model Prescription {
  id            String    @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String?   @unique
  emittedAt     DateTime  @default(now())
  validUntil    DateTime?
  notes         String?

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  items       PrescriptionItem[]

  @@index([patientId])
  @@index([doctorId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(cuid())
  prescriptionId String
  medication     String
  dosage         String
  frequency      String
  duration       String?
  instructions   String?
  order          Int     @default(0)

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}