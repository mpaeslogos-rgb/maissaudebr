// ============================================
// CONFIGURAÇÃO
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Config {
  id   String @id @default(cuid())
  key  String @unique @default("clinic")

  // Dados da clínica
  clinicName      String @default("maissaudebr")
  cnpj            String @default("")
  cnes            String @default("") // Cadastro Nacional de Estabelecimentos de Saúde
  address         String @default("")
  whatsappNumber  String @default("")
  attendanceHours String @default("")
  specialties     String @default("")

  // Telemedicina
  telemedicinePlatform     String @default("")
  telemedicineLinkInfo     String @default("")
  telemedicineInstructions String @default("")
  linkSendTime             String @default("")

  // Pagamentos
  defaultConsultationFee String @default("")
  pixKey                 String @default("")
  paymentLink            String @default("")
  paymentMethods         String @default("")
  paymentInstructions    String @default("")

  // Políticas da clínica
  confirmationPolicy String @default("")
  cancellationPolicy String @default("")

  // Mensagens automáticas para WhatsApp
  welcomeMessage         String @default("")
  confirmationMessage    String @default("")
  reminderMessage        String @default("")
  paymentReminderMessage String @default("")
  humanTransferMessage   String @default("")
  emergencyMessage       String @default("")

  // Regras adicionais para a IA
  otherSettings String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("configs")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PATIENT
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BANK_TRANSFER
  HEALTH_INSURANCE
}

enum AccountPayableStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

enum RiskProfile {
  NONE
  METABOLIC
  CARDIOMETABOLIC
  HIGH
}

enum JourneyStage {
  ONBOARDING
  ACTIVE
  AT_RISK
  COMPLETED
  CHURNED
}

enum CheckInType {
  INITIAL_ASSESSMENT
  MONTHLY_REVIEW
  METABOLIC_REVIEW
  LAB_RESULTS
  FOLLOWUP
}

// ============================================
// USUÁRIOS E AUTENTICAÇÃO
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(RECEPTIONIST)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações 1:1 (um User pode ser um Doctor ou um Patient)
  doctor         Doctor?
  patient        Patient?
  auditLogs      AuditLog[]
  stockMovements StockMovement[]

  @@index([email])
  @@map("users")
}

// ============================================
// MÉDICOS
// ============================================

enum RepasseType {
  PERCENTAGE
  FIXED
}

model Doctor {
  id           String      @id @default(cuid())
  userId       String      @unique
  crm          String      @unique // Conselho Regional de Medicina
  crmState     String      // UF do CRM (ex: "SP", "RJ")
  cpf          String?     // CPF do médico — obrigatório para prescrição digital CFM
  specialty    String
  phone        String?
  bio          String?
  consultationFee Float?
  workStartHour Int        @default(8)
  workEndHour   Int        @default(18)
  // Repasse ao médico por consulta paga
  repasseType  RepasseType @default(PERCENTAGE)
  repasseValue Float?      // % (0-100) ou valor fixo em R$
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  prescriptions   Prescription[]
  transferredChats Chat[]
  doctorPayments  DoctorPayment[]
  examOrders      ExamOrder[]

  @@index([crm])
  @@index([specialty])
  @@map("doctors")
}

// ============================================
// PACIENTES
// ============================================

model Patient {
  id          String    @id @default(cuid())
  userId      String?   @unique // Opcional: paciente pode não ter login
  fullName    String
  cpf         String?   @unique  // Opcional para pacientes criados via WhatsApp
  rg          String?
  birthDate   DateTime?          // Opcional para pacientes criados via WhatsApp
  gender      Gender?            // Opcional para pacientes criados via WhatsApp
  email       String?
  phone       String
  
  // Endereço
  zipCode     String?
  street      String?
  number      String?
  complement  String?
  neighborhood String?
  city        String?
  state       String?

  // Dados clínicos
  bloodType   String?
  allergies   String?
  notes       String?
  riskProfile RiskProfile @default(NONE)

  // Convênio
  healthInsurance     String?
  healthInsuranceNumber String?

  // Foto
  photoUrl    String?

  // LGPD — anonimização
  deletedAt   DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments    Appointment[]
  medicalRecords  MedicalRecord[]
  payments        Payment[]
  chats           Chat[]
  exams           Exam[]
  prescriptions   Prescription[]
  consents        Consent[]
  examOrders      ExamOrder[]
  enrollments     PatientEnrollment[]
  metabolicMarkers MetabolicMarker[]
  npsResponses    NpsResponse[]
  checkIns        CheckIn[]

  @@index([cpf])
  @@index([fullName])
  @@map("patients")
}

// ============================================
// LGPD — CONSENTIMENTO (Art. 7 e Art. 9)
// ============================================
// Registra o consentimento explícito do paciente para cada finalidade de tratamento.
// Finalidades típicas: "tratamento_clinico", "marketing", "compartilhamento_parceiros", etc.

model Consent {
  id          String   @id @default(cuid())
  patientId   String
  purpose     String   // Finalidade do tratamento (ex: "tratamento_clinico")
  granted     Boolean  @default(true) // true = consentiu, false = revogou
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  notes       String?

  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([patientId, purpose])
  @@map("consents")
}

// ============================================
// PRE AGENDAMENTOS
// ============================================

model PreAppointment {
  id          String   @id @default(cuid())
  leadId      String
  doctorId    String
  date        String   // Formato YYYY-MM-DD
  time        String   // Formato HH:MM
  specialty   String
  status      String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("pre_appointments")
}

// ============================================
// AGENDAMENTOS
// ============================================

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  startTime       DateTime
  endTime         DateTime
  status          AppointmentStatus @default(SCHEDULED)
  reason          String?
  notes           String?
  isReturn        Boolean           @default(false)
  insurancePlanId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor         Doctor          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  insurancePlan  InsurancePlan?  @relation(fields: [insurancePlanId], references: [id], onDelete: SetNull)
  medicalRecord  MedicalRecord?
  prescription   Prescription?
  payment        Payment?
  doctorPayment  DoctorPayment?
  examOrders     ExamOrder[]
  stockMovements StockMovement[]
  guia           GuiaFaturamento?
  npsResponse    NpsResponse?

  @@index([patientId])
  @@index([doctorId])
  @@index([startTime])
  @@index([status])
  @@map("appointments")
}

// ============================================
// PRONTUÁRIOS MÉDICOS
// ============================================

model MedicalRecord {
  id              String   @id @default(cuid())
  patientId       String
  doctorId        String
  appointmentId   String?  @unique // 1:1 opcional com Appointment
  
  // Anamnese e diagnóstico
  chiefComplaint   String?  // Queixa principal
  historyOfIllness String?  // História da doença atual
  diagnosis        String?
  prescription     String?  // Prescrição
  observations     String?

  // Sinais vitais
  bloodPressure    String?  // ex: "120/80 mmHg"
  heartRate        Int?     // bpm
  temperature      Float?   // °C
  weight           Float?   // kg
  height           Float?   // cm
  oxygenSaturation Float?   // %

  // Histórico clínico estruturado
  currentMedications String? // Medicamentos em uso
  pastConditions     String? // Antecedentes pessoais
  pastSurgeries      String? // Cirurgias anteriores
  familyHistory      String? // Histórico familiar

  // Hábitos de vida
  smokingStatus    String?  // NEVER | FORMER | CURRENT
  alcoholStatus    String?  // NEVER | OCCASIONAL | REGULAR
  physicalActivity String?  // SEDENTARY | LIGHT | MODERATE | INTENSE

  // Perguntas específicas da especialidade (JSON livre)
  specialtyData    Json?

  // OCR / Anexos (resultados de exames extraídos via OpenAI)
  attachmentUrl   String?  // URL do arquivo original (se salvar storage)
  ocrText         String?  // Texto extraído via OCR
  ocrSummary      String?  // Resumo gerado pela OpenAI

  // Transcrição da consulta
  transcript      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  exams        Exam[]

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@map("medical_records")
}

// ============================================
// EXAMES E RESULTADOS
// ============================================

enum ExamType {
  LABORATORY
  IMAGING
  REPORT
  OTHER
}

enum ExamOrderStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
}

model Exam {
  id              String    @id @default(cuid())
  patientId       String
  medicalRecordId String?

  name            String
  type            ExamType  @default(OTHER)
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  mimeType        String?
  ocrText         String?
  notes           String?
  examDate        DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicalRecord MedicalRecord? @relation(fields: [medicalRecordId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([medicalRecordId])
  @@map("exams")
}

// ============================================
// PAGAMENTOS (CONTAS A RECEBER)
// ============================================

model Payment {
  id              String         @id @default(cuid())
  patientId       String
  appointmentId   String?        @unique
  enrollmentId    String?
  amount          Float
  status          PaymentStatus  @default(PENDING)
  method          PaymentMethod?
  dueDate         DateTime
  paidAt          DateTime?
  description     String?
  invoiceUrl      String?        // Link da nota fiscal (se houver)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  patient        Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment    Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  enrollment     PatientEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  doctorPayment  DoctorPayment?
  examOrder      ExamOrder?

  @@index([patientId])
  @@index([status])
  @@index([dueDate])
  @@map("payments")
}

// ============================================
// REPASSES AOS MÉDICOS
// ============================================

enum DoctorPaymentStatus {
  PENDING
  PAID
  CANCELLED
}

model DoctorPayment {
  id            String              @id @default(cuid())
  doctorId      String
  appointmentId String?             @unique  // null para repasses de exame sem consulta vinculada
  paymentId     String?             @unique  // pagamento do paciente que gerou o repasse
  amount        Float
  status        DoctorPaymentStatus @default(PENDING)
  paidAt        DateTime?
  nfNumber      String?             // Número da NF ou Recibo do médico
  nfFileUrl     String?             // URL do arquivo da NF (opcional)
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  payment     Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  examOrder   ExamOrder?

  @@index([doctorId])
  @@index([status])
  @@index([appointmentId])
  @@map("doctor_payments")
}

// ============================================
// CONTAS A PAGAR (despesas da clínica)
// ============================================

model AccountPayable {
  id          String               @id @default(cuid())
  description String
  category    String?              // Ex: "Aluguel", "Energia", "Material"
  supplier    String?              // Fornecedor
  supplierCnpj  String?
  digitableLine String?
  barcode       String?
  bankCode      String?
  fileUrl       String?
  ocrRawText    String?
  ocrConfidence Float?
  ocrStatus     String   @default("PENDING")
  amount      Float
  status      AccountPayableStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([category])
  @@map("accounts_payable")
}

// ============================================
// AUDITORIA (LGPD / rastreabilidade)
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // Ex: "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity     String   // Ex: "Patient", "Appointment"
  entityId   String?
  metadata   Json?    // Dados adicionais (antes/depois, IP, etc.)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  specialty String?
  status    String   @default("NOVO")

  // Campos opcionais capturados na importação Excel
  cpf                   String?
  rg                    String?
  birthDate             DateTime?
  gender                String?
  email                 String?
  zipCode               String?
  street                String?
  number                String?
  complement            String?
  neighborhood          String?
  city                  String?
  state                 String?
  bloodType             String?
  allergies             String?
  notes                 String?
  healthInsurance       String?
  healthInsuranceNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model ChatLog {
  id        String   @id @default(cuid())
  phone     String   @default("simulador")
  intent    String?  // agendamento, pagamento, urgencia, humano, etc.
  message   String
  isUser    Boolean  @default(true)
  
  createdAt DateTime @default(now())

  @@map("chat_logs")
}

model Chat {
  id          String      @id @default(cuid())
  phone       String      @unique
  patientId   String?
  status      ChatStatus  @default(ACTIVE)
  aiPaused    Boolean     @default(false)
  transferredToDoctorId   String?
  pendingTransferDoctorId String?
  lastMessageAt DateTime  @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  patient     Patient?    @relation(fields: [patientId], references: [id])
  doctor      Doctor?     @relation(fields: [transferredToDoctorId], references: [id])

  @@map("chats")
}

enum ChatStatus {
  ACTIVE
  TRANSFERRED_TO_DOCTOR
  CLOSED
}

// ============================================
// PRESCRIÇÕES MÉDICAS
// ============================================

model Prescription {
  id            String    @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String?   @unique
  emittedAt     DateTime  @default(now())
  validUntil    DateTime?
  notes         String?

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  items       PrescriptionItem[]

  @@index([patientId])
  @@index([doctorId])
  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(cuid())
  prescriptionId String
  medication     String
  dosage         String
  frequency      String
  duration       String?
  instructions   String?
  order          Int     @default(0)

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@map("prescription_items")
}

// ============================================
// CONVÊNIOS / PLANOS DE SAÚDE
// ============================================

model InsurancePlan {
  id          String   @id @default(cuid())
  name        String
  ansCode     String?  // Código ANS (registro da operadora na ANS)
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  // Código do prestador (clínica) junto a esta operadora — obrigatório para XML TISS
  codigoPrestadorNaOperadora String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contracts    InsuranceContract[]
  appointments Appointment[]
  guias        GuiaFaturamento[]
  lotes        LoteFaturamento[]

  @@index([name])
  @@map("insurance_plans")
}

model InsuranceContract {
  id              String    @id @default(cuid())
  planId          String
  startDate       DateTime
  endDate         DateTime?
  consultationFee Float?    // Valor da consulta neste contrato (sobrescreve padrão do médico)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan       InsurancePlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  procedures InsuranceProcedure[]

  @@index([planId])
  @@map("insurance_contracts")
}

model InsuranceProcedure {
  id           String   @id @default(cuid())
  contractId   String
  tussCode     String   // Código TUSS (Terminologia Unificada da Saúde Suplementar)
  description  String
  price        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contract InsuranceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([tussCode])
  @@map("insurance_procedures")
}

// ============================================
// CATÁLOGO DE EXAMES DA CLÍNICA
// ============================================

model ExamCatalog {
  id           String       @id @default(cuid())
  name         String
  description  String?
  price        Float
  duration     Int?         // Duração estimada em minutos
  repasseType  RepasseType?
  repasseValue Float?       // Sobrescreve repasse padrão do médico se preenchido
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orders ExamOrder[]

  @@index([name])
  @@map("exam_catalog")
}

model ExamOrder {
  id            String          @id @default(cuid())
  patientId     String
  doctorId      String
  catalogId     String
  appointmentId String?
  scheduledAt   DateTime?
  completedAt   DateTime?
  status        ExamOrderStatus @default(PENDING)
  notes         String?
  paymentId     String?         @unique
  doctorPaymentId String?       @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  catalog       ExamCatalog    @relation(fields: [catalogId], references: [id])
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  payment       Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  doctorPayment DoctorPayment? @relation(fields: [doctorPaymentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("exam_orders")
}

// ============================================
// ESTOQUE DE MATERIAIS
// ============================================

model Material {
  id           String    @id @default(cuid())
  name         String
  unit         String    // ex: "unidade", "caixa", "frasco"
  minStock     Float     @default(0)
  currentStock Float     @default(0)
  costPrice    Float?    // Custo unitário de compra
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  movements StockMovement[]

  @@index([name])
  @@map("materials")
}

model StockMovement {
  id            String            @id @default(cuid())
  materialId    String
  type          StockMovementType
  quantity      Float
  reason        String?
  appointmentId String?
  userId        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  material    Material     @relation(fields: [materialId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([materialId])
  @@index([type])
  @@map("stock_movements")
}

// ============================================
// TISS — FATURAMENTO A CONVÊNIOS
// ============================================

enum GuiaTipo {
  CONSULTA
  SP_SADT
}

enum GuiaStatus {
  PENDENTE
  AUTORIZADA
  NEGADA
  FATURADA
  PAGA
  GLOSADA
}

enum LoteStatus {
  ABERTO
  FECHADO
  ENVIADO
  LIQUIDADO
}

model LoteFaturamento {
  id              String     @id @default(cuid())
  insurancePlanId String
  numeroLote      Int
  competencia     String     // "YYYY-MM"
  status          LoteStatus @default(ABERTO)
  valorTotal      Float      @default(0)
  dataEnvio       DateTime?
  observacoes     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  plan  InsurancePlan   @relation(fields: [insurancePlanId], references: [id], onDelete: Cascade)
  guias GuiaFaturamento[]

  @@unique([insurancePlanId, numeroLote])
  @@index([insurancePlanId])
  @@index([status])
  @@map("lotes_faturamento")
}

model GuiaFaturamento {
  id              String     @id @default(cuid())
  loteId          String?
  insurancePlanId String
  appointmentId   String?    @unique
  tipo            GuiaTipo
  status          GuiaStatus @default(PENDENTE)
  numeroGuia      String

  // Autorização
  numeroAutorizacao   String?
  dataAutorizacao     DateTime?

  // Beneficiário (desnormalizado para o XML)
  nomeBeneficiario    String
  numeroCarteirinha   String
  validadeCarteirinha String?  // "MM/YYYY"

  // Executante
  codigoPrestadorNaOperadora String?

  // Valores
  valorApresentado Float
  valorAprovado    Float?
  motivoGlosa      String?

  // Dados clínicos (Guia Consulta)
  tipoConsulta       Int?    // 1=1º atend, 2=retorno, 3=pré-natal
  tussCode           String? // código TUSS principal
  cbos               String? // CBOS do médico executante
  crmExecutante      String?
  crmEstado          String?
  nomeExecutante     String?
  indicacaoAcidente  Int     @default(9) // 9=outros, 1=trabalho, 2=trânsito

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lote          LoteFaturamento?  @relation(fields: [loteId], references: [id], onDelete: SetNull)
  plan          InsurancePlan     @relation(fields: [insurancePlanId], references: [id], onDelete: Cascade)
  appointment   Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  procedimentos GuiaProcedimento[]

  @@index([insurancePlanId])
  @@index([loteId])
  @@index([status])
  @@map("guias_faturamento")
}

model GuiaProcedimento {
  id            String  @id @default(cuid())
  guiaId        String
  tussCode      String
  descricao     String
  quantidade    Float   @default(1)
  valorUnitario Float
  valorTotal    Float

  guia GuiaFaturamento @relation(fields: [guiaId], references: [id], onDelete: Cascade)

  @@index([guiaId])
  @@map("guia_procedimentos")
}

// ============================================
// PROGRAMAS PREVENTIVOS
// ============================================

model PreventivoProgram {
  id           String   @id @default(cuid())
  name         String
  description  String?
  durationDays Int      // duração total do programa em dias
  monthlyFee   Float    // mensalidade (R$)
  entryFee     Float    @default(0) // taxa de entrada (R$)
  clinicScope  String?  // escopo clínico (texto livre)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollments PatientEnrollment[]

  @@index([isActive])
  @@map("preventivo_programs")
}

model PatientEnrollment {
  id              String           @id @default(cuid())
  patientId       String
  programId       String
  startDate       DateTime
  endDate         DateTime?
  status          EnrollmentStatus @default(ACTIVE)
  journeyStage    JourneyStage     @default(ONBOARDING)
  monthlyFee      Float            // pode sobrescrever o valor do programa
  nextBillingDate DateTime
  cancelReason    String?
  cancelledAt     DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  program   PreventivoProgram @relation(fields: [programId], references: [id])
  payments  Payment[]
  checkIns  CheckIn[]
  npsResponses NpsResponse[]

  @@index([patientId])
  @@index([status])
  @@index([journeyStage])
  @@index([nextBillingDate])
  @@map("patient_enrollments")
}

// ============================================
// MARCADORES METABÓLICOS
// ============================================

model MetabolicMarker {
  id            String   @id @default(cuid())
  patientId     String
  date          DateTime
  weight        Float?   // kg
  bmi           Float?   // kg/m²
  systolicBP    Float?   // mmHg
  diastolicBP   Float?   // mmHg
  glucose       Float?   // mg/dL (glicemia em jejum)
  hba1c         Float?   // % (hemoglobina glicada)
  totalChol     Float?   // mg/dL (colesterol total)
  ldl           Float?   // mg/dL
  hdl           Float?   // mg/dL
  triglycerides Float?   // mg/dL
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([date])
  @@map("metabolic_markers")
}

// ============================================
// NPS — SATISFAÇÃO PÓS-CONSULTA
// ============================================

model NpsResponse {
  id            String    @id @default(cuid())
  patientId     String
  appointmentId String?   @unique
  enrollmentId  String?
  score         Int       // 0–10 (NPS)
  comment       String?
  sentAt        DateTime? // quando a mensagem Z-API foi enviada
  respondedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  enrollment  PatientEnrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([enrollmentId])
  @@index([score])
  @@map("nps_responses")
}

// ============================================
// CHECK-INS PREVENTIVOS
// ============================================

model CheckIn {
  id           String      @id @default(cuid())
  patientId    String
  enrollmentId String
  scheduledAt  DateTime
  completedAt  DateTime?
  type         CheckInType @default(MONTHLY_REVIEW)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  patient    Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  enrollment PatientEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([enrollmentId])
  @@index([scheduledAt])
  @@map("check_ins")
}