# Banco de dados (fornecido automaticamente pelo Railway PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Autenticação JWT (gere uma string aleatória forte, ex: openssl rand -base64 32)
JWT_SECRET=troque-por-uma-string-secreta-forte

# OpenAI (necessário para OCR de boletos e prontuários)
OPENAI_API_KEY=sk-...

# CORS: URL do frontend no Vercel (sem barra no final)
CORS_ALLOW_ORIGIN=https://seu-app.vercel.app

# Porta (Railway define automaticamente via variável PORT)
PORT=3001

# Ambiente
NODE_ENV=production

# WhatsApp via Evolution API (opcional — lembretes por WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.railway.app
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=nome-da-instancia

# Email via Resend (opcional — lembretes por email)
# Crie conta gratuita em resend.com (100 emails/dia free)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@seu-dominio.com.br
